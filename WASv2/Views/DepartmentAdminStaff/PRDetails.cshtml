@model PRModel

@{
    ViewData["Title"] = $"PR Details - {Model.PRNumber}";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3">PR Details - @Model.PRNumber</h1>
        <a asp-action="Index" class="btn btn-secondary">
            <i class="fa fa-arrow-left me-2"></i>Back to Search
        </a>
    </div>

    <div class="row">
        <div class="col-md-8">
            <div class="card shadow mb-4">
                <div class="card-header @GetStatusColor(Model.Status) text-white">
                    <div class="d-flex justify-content-between align-items-center">
                        <span><i class="fa fa-file-invoice me-2"></i>PR Information</span>
                        <span class="badge bg-light text-dark">@GetStatusDisplay(Model.Status)</span>
                    </div>
                </div>
                <div class="card-body">
                    <!-- Status Timeline -->
                    <div class="mb-4">
                        <h6 class="fw-bold">Status Timeline</h6>
                        <div class="timeline">
                            @if (Model.SubmittedDate != null)
                            {
                                <div class="timeline-item">
                                    <i class="fa fa-check-circle text-success"></i>
                                    <span class="fw-bold">Submitted:</span>
                                    <span>@Model.SubmittedDate.ToString("MMM dd, yyyy HH:mm")</span>
                                </div>
                            }
                            @if (Model.ReviewedDate != null)
                            {
                                <div class="timeline-item">
                                    <i class="fa @(Model.Status == PRStatus.DisapprovedByDepartmentHead ? "fa-times-circle text-danger" : "fa-check-circle text-success")"></i>
                                    <span class="fw-bold">Reviewed @(Model.ReviewedDate?.ToString("MMM dd, yyyy HH:mm"))</span>
                                    @if (!string.IsNullOrEmpty(Model.ApprovalRemarks))
                                    {
                                        <div class="ms-4 text-muted">
                                            <i class="fa fa-comment me-1"></i>@Model.ApprovalRemarks
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    </div>

                    <!-- PR Details -->
                    <div class="row">
                        <div class="col-md-6">
                            <p><strong>Department:</strong> @Model.Department</p>
                            <p><strong>Requested By:</strong> @Model.RequestedBy</p>
                            <p><strong>Request Date:</strong> @Model.RequestDate.ToString("MMM dd, yyyy")</p>
                        </div>
                        <div class="col-md-6">
                            <p><strong>Budget Line:</strong> @Model.BudgetLine</p>
                            <p><strong>Budget Confirmation:</strong> @Model.BudgetConfirmation</p>
                            <p><strong>Total Amount:</strong> <span class="fw-bold">@Model.TotalAmount.ToString("C2")</span></p>
                        </div>
                    </div>

                    <p><strong>Purpose:</strong> @Model.Purpose</p>

                    @if (!string.IsNullOrEmpty(Model.Remarks))
                    {
                        <p><strong>Remarks:</strong> @Model.Remarks</p>
                    }

                    <!-- Items Table -->
                    @if (Model.Items != null && Model.Items.Any())
                    {
                        <h6 class="fw-bold mt-4">Items</h6>
                        <div class="table-responsive">
                            <table class="table table-sm table-bordered">
                                <thead class="table-light">
                                    <tr>
                                        <th>Item No.</th>
                                        <th>Description</th>
                                        <th>Qty</th>
                                        <th>Unit</th>
                                        <th>Unit Price</th>
                                        <th>Total</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model.Items)
                                    {
                                        <tr>
                                            <td>@item.ItemNo</td>
                                            <td>@item.Description</td>
                                            <td>@item.Quantity</td>
                                            <td>@item.Unit</td>
                                            <td>@item.UnitPrice.ToString("C2")</td>
                                            <td>@item.TotalPrice.ToString("C2")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <!-- Document Card -->
            <div class="card shadow mb-4">
                <div class="card-header bg-secondary text-white">
                    <i class="fa fa-file me-2"></i>Documents
                </div>
                <div class="card-body">
                    @if (!string.IsNullOrEmpty(Model.PRFFileName))
                    {
                        <a asp-action="DownloadPRF" asp-route-prNumber="@Model.PRNumber" class="btn btn-outline-primary w-100">
                            <i class="fa fa-download me-2"></i>Download PRF
                        </a>
                    }
                    else
                    {
                        <p class="text-muted mb-0">No documents uploaded</p>
                    }
                </div>
            </div>

            <!-- Approval/Disapproval Details (if any) -->
            @if (Model.Status == PRStatus.ApprovedByDepartmentHead || Model.Status == PRStatus.DisapprovedByDepartmentHead)
            {
                <div class="card shadow">
                    <div class="card-header @(Model.Status == PRStatus.ApprovedByDepartmentHead ? "bg-success" : "bg-danger") text-white">
                        <i class="fa @(Model.Status == PRStatus.ApprovedByDepartmentHead ? "fa-check" : "fa-times") me-2"></i>
                        @(Model.Status == PRStatus.ApprovedByDepartmentHead ? "Approval Details" : "Disapproval Details")
                    </div>
                    <div class="card-body">
                        <p><strong>Reviewed By:</strong> @Model.ReviewedBy</p>
                        <p><strong>Reviewed Date:</strong> @(Model.ReviewedDate?.ToString("MMM dd, yyyy HH:mm"))</p>
                        @if (!string.IsNullOrEmpty(Model.ApprovalRemarks))
                        {
                            <p><strong>Remarks:</strong> @Model.ApprovalRemarks</p>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@functions {
    private string GetStatusColor(string status)
    {
        return status switch
        {
            var s when s == PRStatus.PendingDepartmentHeadApproval => "bg-warning",
            var s when s == PRStatus.ApprovedByDepartmentHead => "bg-success",
            var s when s == PRStatus.DisapprovedByDepartmentHead => "bg-danger",
            var s when s == PRStatus.PendingDirectorApproval => "bg-info",
            _ => "bg-secondary"
        };
    }

    private string GetStatusDisplay(string status)
    {
        return status switch
        {
            var s when s == PRStatus.PendingDepartmentHeadApproval => "Pending Approval",
            var s when s == PRStatus.ApprovedByDepartmentHead => "Approved",
            var s when s == PRStatus.DisapprovedByDepartmentHead => "Disapproved",
            var s when s == PRStatus.PendingDirectorApproval => "With Director",
            _ => status
        };
    }
}