@model WASv2.Controllers.PRFViewModel
@using WASv2.Models

@{
    ViewData["Title"] = "Department Admin Staff - PRF Management";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3">Department Admin Staff - PRF Management</h1>
        <div class="text-end">
            <span class="badge bg-primary p-2">Role: Dept Admin Staff - IT</span>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row">
        <!-- ── LEFT: Search + PRF Details ───────────────────────────────── -->
        <div class="col-md-8">
            <!-- PR Number Search Card -->
            <div class="card shadow mb-4">
                <div class="card-header bg-primary text-white">
                    <i class="fa fa-search me-2"></i>Search PRF by PR Number
                </div>
                <div class="card-body">
                    <form asp-action="SearchPR" method="post" id="searchForm">
                        <div class="input-group mb-3">
                            <input type="text" class="form-control form-control-lg"
                                   asp-for="PRNumber"
                                   placeholder="(PR-2026-001)" />
                            <button class="btn btn-primary" type="submit">
                                <i class="fa fa-search me-2"></i>Search
                            </button>
                        </div>
                        <span asp-validation-for="PRNumber" class="text-danger"></span>
                    </form>
                </div>
            </div>

            @if (Model.IsSearched)
            {
                if (Model.IsFound)
                {
                    <!-- PRF Details Card -->
                    <div class="card shadow mb-4">
                        <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
                            <span><i class="fa fa-file-invoice me-2"></i>PRF Details - @Model.PRNumber</span>
                            @if (!string.IsNullOrEmpty(Model.PRFFileName))
                            {
                                <a asp-action="DownloadPRF"
                                   asp-route-prNumber="@Model.PRNumber"
                                   class="btn btn-sm btn-light"
                                   title="Download PRF">
                                    <i class="fa fa-download me-1"></i>Download PRF
                                </a>
                            }
                        </div>
                        <div class="card-body">
                            <form asp-action="SubmitToDeptHead" method="post" enctype="multipart/form-data">
                                <input type="hidden" asp-for="PRNumber" />
                                <input type="hidden" asp-for="Department" />
                                <input type="hidden" asp-for="RequestDate" />
                                <input type="hidden" asp-for="RequestedBy" />
                                <input type="hidden" asp-for="Purpose" />
                                <input type="hidden" asp-for="BudgetLine" />
                                <input type="hidden" asp-for="TotalAmount" />
                                <input type="hidden" asp-for="PRFFileName" />

                                @if (Model.Items != null)
                                {
                                    for (int i = 0; i < Model.Items.Count; i++)
                                    {
                                        <input type="hidden" name="Items[@i].ItemNo" value="@Model.Items[i].ItemNo" />
                                        <input type="hidden" name="Items[@i].Description" value="@Model.Items[i].Description" />
                                        <input type="hidden" name="Items[@i].Quantity" value="@Model.Items[i].Quantity" />
                                        <input type="hidden" name="Items[@i].Unit" value="@Model.Items[i].Unit" />
                                        <input type="hidden" name="Items[@i].UnitPrice" value="@Model.Items[i].UnitPrice" />
                                        <input type="hidden" name="Items[@i].TotalPrice" value="@Model.Items[i].TotalPrice" />
                                    }
                                }

                                <!-- PRF Information -->
                                <div class="row mb-3">
                                    <div class="col-md-6">
                                        <div class="mb-3">
                                            <label class="form-label fw-bold">Department</label>
                                            <p class="form-control-plaintext">@Model.Department</p>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="mb-3">
                                            <label class="form-label fw-bold">Request Date</label>
                                            <p class="form-control-plaintext">@Model.RequestDate.ToString("MMM dd, yyyy")</p>
                                        </div>
                                    </div>
                                </div>

                                <div class="row mb-3">
                                    <div class="col-md-6">
                                        <div class="mb-3">
                                            <label class="form-label fw-bold">Requested By</label>
                                            <p class="form-control-plaintext">@Model.RequestedBy</p>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="mb-3">
                                            <label class="form-label fw-bold">Budget Line</label>
                                            <p class="form-control-plaintext">@Model.BudgetLine</p>
                                        </div>
                                    </div>
                                </div>

                                <div class="mb-3">
                                    <label class="form-label fw-bold">Purpose</label>
                                    <p class="form-control-plaintext">@Model.Purpose</p>
                                </div>

                                <!-- Items Table -->
                                @if (Model.Items != null && Model.Items.Any())
                                {
                                    <div class="mb-3">
                                        <label class="form-label fw-bold">Items</label>
                                        <div class="table-responsive">
                                            <table class="table table-sm table-bordered">
                                                <thead class="table-light">
                                                    <tr>
                                                        <th>Item No.</th>
                                                        <th>Description</th>
                                                        <th>Qty</th>
                                                        <th>Unit</th>
                                                        <th>Unit Price</th>
                                                        <th>Total</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @foreach (var item in Model.Items)
                                                    {
                                                        <tr>
                                                            <td>@item.ItemNo</td>
                                                            <td>@item.Description</td>
                                                            <td>@item.Quantity</td>
                                                            <td>@item.Unit</td>
                                                            <td>@item.UnitPrice.ToString("C2")</td>
                                                            <td>@item.TotalPrice.ToString("C2")</td>
                                                        </tr>
                                                    }
                                                </tbody>
                                                <tfoot class="table-secondary">
                                                    <tr>
                                                        <td colspan="5" class="text-end fw-bold">Total Amount:</td>
                                                        <td class="fw-bold">@Model.TotalAmount.ToString("C2")</td>
                                                    </tr>
                                                </tfoot>
                                            </table>
                                        </div>
                                    </div>
                                }

                                <!-- Budget Confirmation -->
                                <div class="row mb-3">
                                    <div class="col-md-6">
                                        <label class="form-label fw-bold">Budget Confirmation</label>
                                        <select class="form-select" asp-for="BudgetConfirmation">
                                            <option>Confirmed (Stock Replenishment)</option>
                                            <option>Subject for Approval</option>
                                        </select>
                                    </div>
                                </div>

                                <!-- Upload PRF -->
                                <div class="mb-3">
                                    <label class="form-label fw-bold">Upload PRF (Scanned/PDF)</label>
                                    <input type="file" class="form-control" name="prfFile" accept=".pdf,.jpg,.jpeg,.png" />
                                    <small class="text-muted">Upload new file or use existing: @Model.PRFFileName</small>
                                </div>

                                <!-- Remarks -->
                                <div class="mb-3">
                                    <label class="form-label fw-bold">Remarks/Reason</label>
                                    <textarea class="form-control" asp-for="Remarks" rows="3"></textarea>
                                </div>

                                <!-- Submit Button -->
                                <button type="submit" class="btn btn-primary w-100">
                                    <i class="fa fa-paper-plane me-2"></i>Submit to Department Head
                                </button>
                            </form>
                        </div>
                    </div>
                }
                else
                {
                    <div class="alert alert-warning">
                        <i class="fa fa-exclamation-triangle me-2"></i>
                        PR Number "@Model.PRNumber" not found. Please check the number and try again.
                    </div>
                }
            }
        </div>

        <!-- ── RIGHT: Sidebar ───────────────────────────────────────────── -->
        <div class="col-md-4">

            <!-- ── Recent PR Activity (collapsible) ─────────────────────── -->
            <div class="card shadow mb-4">
                <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center"
                     role="button"
                     data-bs-toggle="collapse"
                     data-bs-target="#collapseRecentActivity"
                     aria-expanded="true"
                     aria-controls="collapseRecentActivity"
                     style="cursor:pointer; user-select:none;">
                    <span><i class="fa fa-clock me-2"></i>Recent PR Activity</span>
                    <div class="d-flex align-items-center gap-2">
                        <span class="badge bg-light text-dark">@(ViewBag.TotalPRs ?? 0) Total</span>
                        <i class="fa fa-chevron-up collapse-chevron transition-icon"></i>
                    </div>
                </div>
                <div id="collapseRecentActivity" class="collapse show">
                    <div class="card-body p-0">
                        @if (ViewBag.RecentPRs != null && ((List<PRModel>)ViewBag.RecentPRs).Any())
                        {
                            <ul class="list-group list-group-flush">
                                @foreach (var pr in (List<PRModel>)ViewBag.RecentPRs)
                                {
                                    <li class="list-group-item">
                                        <div class="d-flex justify-content-between align-items-start">
                                            <div>
                                                <strong>@pr.PRNumber</strong>
                                                <br />
                                                <small class="text-muted">@pr.Purpose</small>
                                            </div>
                                            <div>
                                                @switch (pr.Status)
                                                {
                                                    case var s when s == PRStatus.PendingDepartmentHeadApproval:
                                                        <span class="badge bg-warning">Pending</span>
                                                        break;
                                                    case var s when s == PRStatus.ApprovedByDepartmentHead:
                                                        <span class="badge bg-success">Approved</span>
                                                        break;
                                                    case var s when s == PRStatus.DisapprovedByDepartmentHead:
                                                        <span class="badge bg-danger">Disapproved</span>
                                                        break;
                                                    case var s when s == PRStatus.PendingDirectorApproval:
                                                        <span class="badge bg-info">With Director</span>
                                                        break;
                                                }
                                            </div>
                                        </div>
                                        @if (!string.IsNullOrEmpty(pr.ApprovalRemarks))
                                        {
                                            <small class="text-muted d-block mt-1">
                                                <i class="fa fa-comment me-1"></i>@pr.ApprovalRemarks
                                            </small>
                                        }
                                        <small class="text-muted d-block mt-1">
                                            <i class="fa fa-calendar me-1"></i>@pr.SubmittedDate.ToString("MMM dd, yyyy")
                                        </small>
                                    </li>
                                }
                            </ul>
                        }
                        else
                        {
                            <div class="text-center p-3">
                                <p class="text-muted mb-0">No recent PR activity</p>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- ── Approved PRs (collapsible) ───────────────────────────── -->
            @{
                var approvedPRs = ViewBag.ApprovedPRs as List<PRModel> ?? new List<PRModel>();
            }
            <div class="card shadow mb-4">
                <div class="card-header bg-success text-white d-flex justify-content-between align-items-center"
                     role="button"
                     data-bs-toggle="collapse"
                     data-bs-target="#collapseApprovedPRs"
                     aria-expanded="true"
                     aria-controls="collapseApprovedPRs"
                     style="cursor:pointer; user-select:none;">
                    <span><i class="fa fa-check-circle me-2"></i>Approved PRs</span>
                    <div class="d-flex align-items-center gap-2">
                        <span class="badge bg-light text-dark">@approvedPRs.Count</span>
                        <i class="fa fa-chevron-up collapse-chevron transition-icon"></i>
                    </div>
                </div>
                <div id="collapseApprovedPRs" class="collapse show">
                    <div class="card-body p-0">
                        @if (approvedPRs.Any())
                        {
                            <ul class="list-group list-group-flush">
                                @foreach (var pr in approvedPRs)
                                {
                                    <li class="list-group-item">
                                        <div class="d-flex justify-content-between align-items-start">
                                            <div>
                                                <strong>@pr.PRNumber</strong>
                                                <br />
                                                <small class="text-muted">@pr.Purpose</small>
                                            </div>
                                            <span class="badge bg-success">Approved</span>
                                        </div>
                                        <small class="text-muted d-block mt-1">
                                            <i class="fa fa-user me-1"></i>Reviewed by: @(pr.ReviewedBy ?? "—")
                                        </small>
                                        @if (!string.IsNullOrEmpty(pr.ApprovalRemarks))
                                        {
                                            <small class="text-muted d-block">
                                                <i class="fa fa-comment me-1"></i>@pr.ApprovalRemarks
                                            </small>
                                        }
                                        <small class="text-muted d-block">
                                            <i class="fa fa-calendar me-1"></i>
                                            @(pr.ReviewedDate.HasValue? pr.ReviewedDate.Value.ToString("MMM dd, yyyy") : pr.SubmittedDate.ToString("MMM dd, yyyy"))
                                        </small>
                                    </li>
                                }
                            </ul>
                        }
                        else
                        {
                            <div class="text-center p-3">
                                <p class="text-muted mb-0">No approved PRs yet</p>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- ── Disapproved PRs (collapsible) ────────────────────────── -->
            @{
                var disapprovedPRs = ViewBag.DisapprovedPRs as List<PRModel> ?? new List<PRModel>();
            }
            <div class="card shadow mb-4">
                <div class="card-header bg-danger text-white d-flex justify-content-between align-items-center"
                     role="button"
                     data-bs-toggle="collapse"
                     data-bs-target="#collapseDisapprovedPRs"
                     aria-expanded="true"
                     aria-controls="collapseDisapprovedPRs"
                     style="cursor:pointer; user-select:none;">
                    <span><i class="fa fa-times-circle me-2"></i>Disapproved PRs</span>
                    <div class="d-flex align-items-center gap-2">
                        <span class="badge bg-light text-dark">@disapprovedPRs.Count</span>
                        <i class="fa fa-chevron-up collapse-chevron transition-icon"></i>
                    </div>
                </div>
                <div id="collapseDisapprovedPRs" class="collapse show">
                    <div class="card-body p-0">
                        @if (disapprovedPRs.Any())
                        {
                            <ul class="list-group list-group-flush">
                                @foreach (var pr in disapprovedPRs)
                                {
                                    <li class="list-group-item">
                                        <div class="d-flex justify-content-between align-items-start">
                                            <div>
                                                <strong>@pr.PRNumber</strong>
                                                <br />
                                                <small class="text-muted">@pr.Purpose</small>
                                            </div>
                                            <span class="badge bg-danger">Disapproved</span>
                                        </div>
                                        <small class="text-muted d-block mt-1">
                                            <i class="fa fa-user me-1"></i>Reviewed by: @(pr.ReviewedBy ?? "—")
                                        </small>
                                        <small class="text-muted d-block mt-1">
                                            <i class="fa fa-user me-1"></i>Requested by: @(pr.RequestedBy ?? "—")
                                        </small>
                                        @if (!string.IsNullOrEmpty(pr.ApprovalRemarks))
                                        {
                                            <small class="text-danger d-block">
                                                <i class="fa fa-comment me-1"></i>@pr.ApprovalRemarks
                                            </small>
                                        }
                                        <small class="text-muted d-block">
                                            <i class="fa fa-calendar me-1"></i>
                                            @(pr.ReviewedDate.HasValue? pr.ReviewedDate.Value.ToString("MMM dd, yyyy") : pr.SubmittedDate.ToString("MMM dd, yyyy"))
                                        </small>
                                    </li>
                                }
                            </ul>
                        }
                        else
                        {
                            <div class="text-center p-3">
                                <p class="text-muted mb-0">No disapproved PRs</p>
                            </div>
                        }
                    </div>
                </div>
            </div>

        </div>
        <!-- end sidebar -->
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <style>
        .transition-icon {
            transition: transform 0.25s ease;
        }
    </style>
    <script>
        $(document).ready(function () {
            // Auto-hide alerts after 5 seconds
            setTimeout(function () {
                $(".alert").fadeOut("slow");
            }, 5000);

            // Search form validation
            $("#searchForm").submit(function (e) {
                var prNumber = $("#PRNumber").val();
                if (!prNumber || prNumber.trim() === "") {
                    e.preventDefault();
                    alert("Please enter a PR Number");
                }
            });

            // Rotate chevron on collapse toggle
            // Use Bootstrap's native collapse events for reliable state tracking
            $('[data-bs-toggle="collapse"]').each(function () {
                var $trigger = $(this);
                var targetId = $trigger.data('bs-target');
                var $chevron = $trigger.find('.collapse-chevron');

                $(targetId).on('hide.bs.collapse', function () {
                    $chevron.css('transform', 'rotate(180deg)');
                });

                $(targetId).on('show.bs.collapse', function () {
                    $chevron.css('transform', 'rotate(0deg)');
                });
            });
        });
    </script>
}
