@model IEnumerable<WASv2.Models.PRModel>
@{
    ViewData["Title"] = "Manager/Director Dashboard";
    var pendingCount = ViewBag.PendingCount;
    var totalAmount = ViewBag.TotalAmount;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3">MANAGER/DIRECTOR</h1>
    <div class="text-end">
        <span class="badge bg-primary p-2">Role: Manager/Director</span>
    </div>
</div>

<div class="row mb-4">
    <div class="col-md-4">
        <div class="card shadow-sm border-0 bg-primary text-white">
            <div class="card-body">
                <h6>Awaiting Director Approval</h6>
                <h2 class="display-6">@pendingCount</h2>
                <p class="mb-0 small text-white-50">PRs forwarded by Dept Heads</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm border-0 bg-info text-white">
            <div class="card-body">
                <h6>Total Amount Pending</h6>
                <h2 class="display-6">@totalAmount.ToString("C2")</h2>
                <p class="mb-0 small text-white-50">Combined value</p>
            </div>
        </div>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card shadow">
    <div class="card-header py-3">
        <h6 class="m-0 font-weight-bold text-primary">Pending Purchase Requisitions</h6>
    </div>
    <div class="table-responsive">
        <table class="table align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>PR Reference</th>
                    <th>Originating Dept</th>
                    <th>Purpose</th>
                    <th>Total Amount</th>
                    <th>Budget Impact</th>
                    <th>Approved by Dept Head</th>
                    <th>Dept Head Approval Date</th>
                    <th class="text-center">Action</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="8" class="text-center text-muted py-4">No pending PRs awaiting Director approval.</td>
                    </tr>
                }
                @foreach (var pr in Model)
                {
                    <tr>
                        <td><strong>@pr.PRNumber</strong></td>
                        <td>@pr.Department</td>
                        <td>@pr.Purpose</td>
                        <td>@pr.TotalAmount.ToString("C2")</td>
                        <td>
                            @if (pr.TotalAmount > 100000)
                            {
                                <span class="badge bg-danger">High</span>
                            }
                            else
                            {
                                <span class="badge bg-success">Normal</span>
                            }
                        </td>
                        <td>
                            @if (!string.IsNullOrEmpty(pr.ReviewedBy))
                            {
                                <span class="text-muted small"><i class="bi bi-person-check"></i> @pr.ReviewedBy</span>
                            }
                            else
                            {
                                <span class="text-muted small">—</span>
                            }
                        </td>
                        <td>
                            @if (pr.ReviewedDate.HasValue)
                            {
                                <span class="text-muted small">@pr.ReviewedDate.Value.ToString("MM/dd/yyyy hh:mm tt")</span>
                            }
                            else
                            {
                                <span class="text-muted small">—</span>
                            }
                        </td>
                        <td class="text-center">
                            <a asp-action="DirectorPReview" asp-route-prNumber="@pr.PRNumber" class="btn btn-sm btn-primary">Review</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>